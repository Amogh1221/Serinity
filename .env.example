# Ollama local inference
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM1_MODEL=phi4-mini
OLLAMA_LLM2_MODEL=qwen2.5:7b-instruct
GROQ_LLM1_MODEL=llama-3.1-8b-instant
GROQ_LLM2_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB local vector store
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=mhcva-knowledge

# SQLite memory store
MEMORY_DB_PATH=./data/serinity.db

# Debug logs directory
LOG_DIR=./logs

# Working memory window (number of raw turns to keep in active context)
WORKING_MEMORY_TURNS=20

## API Keys
GROQ_API_KEY="groq_api_key"

## VectorDB
PINECONE_API_KEY="pinecone_api_key"

## Auth
JWT_SECRET_KEY="jwt_secret_key"
JWT_ALGORITHM="jut_algorithm"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Logging
BETTERSTACK_SOURCE_TOKEN="Betterstack_source_token"

## Database
TURSO_DATABASE_URL="turso_database_url"
TURSO_AUTH_TOKEN="turso_auth_token"

## Environment toggles
CLOUD_MODE=false ## determine it works locally or online

# LLM Provider selection (when CLOUD_MODE=true)
# Options: "groq" | "hf"  (hf = HuggingFace Serverless Inference API)
LLM_PROVIDER=hf

# HuggingFace Serverless Inference API
# Get token at https://huggingface.co/settings/tokens  (read access is enough)
HF_TOKEN="hf_your_token_here"
HF_LLM1_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_LLM2_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Brevo Email OTP
BREVO_API_KEY="brevo_api_key"
